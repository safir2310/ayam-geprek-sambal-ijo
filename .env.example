# Database - PostgreSQL (Neon / Vercel Postgres)
# Example Neon connection string (replace with your own)
DATABASE_URL="postgresql://user:password@ep-xxx.aws.neon.tech/database?sslmode=require"

# Alternative parameters for manual connection
# PGHOST="ep-xxx.aws.neon.tech"
# PGUSER="neondb_owner"
# PGDATABASE="neondb"
# PGPASSWORD="your-password"

# Environment
NODE_ENV="production"

# WebSocket (Optional - for development only)
# In production, use a separate WebSocket service
# WEBSOCKET_URL="http://localhost:3003"

# NextAuth (Optional - if needed in future)
# NEXTAUTH_URL="https://your-domain.com"
# NEXTAUTH_SECRET="your-secret-key"

# Custom Configuration
# NEXT_PUBLIC_APP_URL="https://your-domain.com"
